<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/findDoctorLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".FindDoctorActivity"
    android:padding="8dp">

    <!-- Search Bar -->
    <EditText
        android:id="@+id/searchBar"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Search doctors by name or specialty"
        android:drawableLeft="@android:drawable/ic_menu_search"
        android:drawablePadding="10dp"
        android:padding="12dp"
        android:textColor="#880E4F"
        android:textColorHint="#D81B60"
        android:background="@drawable/searchbar_rounded_bg"
        android:layout_alignParentTop="true"
        android:layout_marginBottom="10dp"
        android:layout_marginTop="6dp"
        android:elevation="2dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:scrollHorizontally="true" />

    <!-- Filter Checkboxes -->
    <LinearLayout
        android:id="@+id/filterLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/searchBar"
        android:orientation="horizontal"
        android:background="#FFEBEE"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:layout_gravity="center_horizontal">

        <CheckBox
            android:id="@+id/availableCheckbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Available"
            android:textStyle="bold"
            android:textColor="#008000"
            android:textSize="14sp" />

        <CheckBox
            android:id="@+id/offlineCheckbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Offline"
            android:textColor="#B71C1C"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginStart="16dp" />
    </LinearLayout>



    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/doctorRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_below="@id/filterLayout"
        android:layout_above="@id/backButton"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:scrollbars="vertical"
        android:background="#FFEBEE"
        android:elevation="2dp" />

    <!-- Back Button -->
    <Button
        android:id="@+id/backButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Back"
        android:backgroundTint="#003366"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_margin="16dp" />
</RelativeLayout>