<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#F5F5F5"
    tools:context=".CartActivity">

    <!-- 🩺 App Logo -->
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/appIcon"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/ic_healthify_logo"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="8dp" />

    <!-- 📛 App Title -->
    <TextView
        android:id="@+id/appTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Healthify Mini"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#00BCD4"
        android:layout_below="@id/appIcon"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="24dp" />

    <!-- 🛒 Cart Title -->
    <TextView
        android:id="@+id/tvCartTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Cart"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_below="@id/appTitle"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="16dp" />

    <!-- ❗ Empty Cart Message -->
    <TextView
        android:id="@+id/tvEmptyCart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="Your cart is empty"
        android:textSize="18sp"
        android:textColor="#888888"
        android:gravity="center"
        android:visibility="gone" />

    <!-- 💊 Cart Item List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCart"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_below="@id/tvCartTitle"
        android:layout_above="@id/tvTotalPrice"
        android:layout_marginBottom="8dp"
        android:layout_marginTop="8dp" />

    <!-- 💰 Total Price -->
    <TextView
        android:id="@+id/tvTotalPrice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/bottomButtons"
        android:layout_marginBottom="16dp"
        android:text="Total: Rs. 0.00"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#5E17EB"
        android:gravity="end" />

    <!-- 🔘 Bottom Buttons -->
    <LinearLayout
        android:id="@+id/bottomButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:weightSum="2"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Back"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#999999"
            android:layout_marginEnd="8dp"
            android:elevation="4dp" />

        <Button
            android:id="@+id/btnCheckout"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Checkout"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#5E17EB"
            android:layout_marginStart="8dp"
            android:elevation="4dp" />
    </LinearLayout>

</RelativeLayout>
