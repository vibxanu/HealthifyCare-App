<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E3F2FD"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- 🠔 Fixed Back Button (48dp + correct tint attribute) -->
        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="start"
            android:background="@drawable/rounded_back_button"
            android:src="@drawable/ic_back"
            android:contentDescription="Back"
            app:tint="#E3F2FD"
            android:layout_marginBottom="16dp"
            android:scaleType="centerInside"
            android:padding="4dp" />

        <!-- 🎀 Title -->
        <TextView
            android:id="@+id/appointmentSummaryTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" Appointment Summary"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#4B0082"
            android:layout_marginBottom="24dp" />

        <!-- 📋 Summary Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_card"
            android:elevation="4dp"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:layout_marginHorizontal="8dp"
            android:layout_gravity="center"
            android:clipToOutline="true">

            <TextView
                android:id="@+id/detailDoctor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👨‍⚕️ Doctor:"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/detailName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🙍‍♂️ Name:"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/detailContact"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📱 Contact:"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/detailGender"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚻 Gender:"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/detailProblem"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💬 Problem:"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/detailDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅 Date:"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/detailTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏰ Time:"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />
        </LinearLayout>

        <!-- 🏠 Home Button (fixed tint + correct touch size already) -->
        <ImageButton
            android:id="@+id/homeButton"
            android:layout_width="98dp"
            android:layout_height="108dp"
            android:layout_gravity="end"
            android:layout_marginBottom="16dp"
            android:background="@drawable/rounded_back_button"
            android:contentDescription="Home"
            android:src="@drawable/ic_home"
            app:tint="#E3F2FD"
            android:scaleType="centerInside" />
    </LinearLayout>
</ScrollView>
